<section class="auth-page">
  <div class="auth-panel p-4 p-lg-5">
    <h1 class="h3 mb-2">My Account</h1>
    <p class="text-muted mb-4">Update your customer profile, contact information, and address details.</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= render "profile_fields", f: f %>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="alert alert-light mt-3">
          Currently waiting confirmation for: <%= resource.unconfirmed_email %>
        </div>
      <% end %>

      <div class="row g-3 mt-1">
        <div class="col-md-6">
          <%= f.label :password, class: "form-label fw-semibold" %>
          <div class="small text-muted mb-1">Leave blank if you do not want to change it.</div>
          <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
          <% if @minimum_password_length %>
            <div class="small text-muted mt-1"><%= @minimum_password_length %> characters minimum</div>
          <% end %>
        </div>

        <div class="col-md-6">
          <%= f.label :password_confirmation, class: "form-label fw-semibold" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
        </div>
      </div>

      <div class="mt-3">
        <%= f.label :current_password, class: "form-label fw-semibold" %>
        <div class="small text-muted mb-1">Only needed when changing your email or password.</div>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control" %>
      </div>

      <div class="d-flex flex-column flex-sm-row gap-2 mt-4">
        <%= f.submit "Update account", class: "btn btn-primary" %>
        <%= link_to "Back to products", products_path, class: "btn btn-outline-secondary" %>
      </div>
    <% end %>

    <div class="auth-danger mt-5 pt-4 border-top">
      <h2 class="h5 mb-2">Cancel account</h2>
      <p class="text-muted">Unhappy with your account? You can remove it here.</p>
      <%= button_to "Cancel my account",
                    registration_path(resource_name),
                    data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" },
                    method: :delete,
                    class: "btn btn-outline-danger" %>
    </div>
  </div>
</section>
