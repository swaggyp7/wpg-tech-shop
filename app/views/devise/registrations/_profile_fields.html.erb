<div class="row g-3">
  <div class="col-12">
    <%= f.label :name, class: "form-label fw-semibold" %>
    <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "form-control" %>
  </div>

  <div class="col-12">
    <%= f.label :email, class: "form-label fw-semibold" %>
    <%= f.email_field :email, autocomplete: "email", class: "form-control" %>
  </div>

  <div class="col-12">
    <%= f.label :address, class: "form-label fw-semibold" %>
    <%= f.text_field :address, autocomplete: "street-address", class: "form-control" %>
  </div>

  <div class="col-md-6">
    <%= f.label :city, class: "form-label fw-semibold" %>
    <%= f.text_field :city, autocomplete: "address-level2", class: "form-control" %>
  </div>

  <div class="col-md-3">
    <%= f.label :province, class: "form-label fw-semibold" %>
    <%= f.text_field :province, autocomplete: "address-level1", class: "form-control" %>
  </div>

  <div class="col-md-3">
    <%= f.label :postal_code, class: "form-label fw-semibold" %>
    <%= f.text_field :postal_code, autocomplete: "postal-code", class: "form-control" %>
  </div>
</div>
