<header class="site-header">
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container py-2">
      <%= link_to "Wpg Online Shop", root_path, class: "navbar-brand" %>

      <div class="d-flex flex-wrap align-items-center gap-2 ms-lg-auto">
        <%= link_to "Products", products_path, class: "nav-link px-2" %>

        <% if customer_signed_in? %>
          <%= link_to cart_path, class: "site-header__cart", aria: { label: "Shopping cart" } do %>
            <span class="site-header__cart-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M3 4h2.3l1.1 2.6 1.8 7.6h9.6l2.3-6.8H8.1" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"/>
                <circle cx="10" cy="19" r="1.6" fill="currentColor"/>
                <circle cx="18" cy="19" r="1.6" fill="currentColor"/>
              </svg>
            </span>
            <span class="site-header__cart-badge"><%= current_cart_item_count %></span>
          <% end %>

          <span class="site-header__status text-white-50 px-2">
            Signed in as <strong class="text-white"><%= customer_display_name(current_customer) %></strong>
          </span>
          <%= link_to "My Account", edit_customer_registration_path, class: "btn btn-outline-light btn-sm" %>
          <%= button_to "Log out",
                        destroy_customer_session_path,
                        method: :delete,
                        class: "btn btn-light btn-sm",
                        form: { class: "d-inline-block mb-0" } %>
        <% else %>
          <%= link_to "Log in", new_customer_session_path, class: "btn btn-outline-light btn-sm" %>
          <%= link_to "Sign up", new_customer_registration_path, class: "btn btn-light btn-sm" %>
        <% end %>
      </div>
    </div>
  </nav>
</header>
