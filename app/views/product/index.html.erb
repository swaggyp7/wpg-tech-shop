<section class="catalog-toolbar p-4 mb-4">
  <div class="d-flex flex-column gap-4">
    <div class="d-flex flex-column flex-xl-row justify-content-between gap-3">
      <div>
        <h2 class="h4 fw-bold mb-2">Advance Search Bar</h2>
        <p class="text-muted mb-0">
          Search by name, price range, on-sale status, category, and sort by price.
        </p>
      </div>

      <div class="align-self-xl-end">
        <span class="badge text-bg-dark fs-6 px-3 py-2">
          <%= pluralize(@products.total_count, "product") %> found
        </span>
      </div>
    </div>

    <%= form_with url: products_path, method: :get, local: true, class: "row g-3 align-items-end" do %>
      <div class="col-12 col-xl-4">
        <%= label_tag :query, "Product Name", class: "form-label fw-semibold" %>
        <%= text_field_tag :query,
                           @search_query,
                           class: "form-control",
                           placeholder: "Search product title" %>
      </div>

      <div class="col-6 col-md-3 col-xl-2">
        <%= label_tag :min_price, "Min Price", class: "form-label fw-semibold" %>
        <%= number_field_tag :min_price,
                             @min_price,
                             class: "form-control",
                             min: 0,
                             step: 0.01,
                             placeholder: "0.00" %>
      </div>

      <div class="col-6 col-md-3 col-xl-2">
        <%= label_tag :max_price, "Max Price", class: "form-label fw-semibold" %>
        <%= number_field_tag :max_price,
                             @max_price,
                             class: "form-control",
                             min: 0,
                             step: 0.01,
                             placeholder: "999.99" %>
      </div>

      <div class="col-12 col-md-3 col-xl-2">
        <%= label_tag :on_sale, "On Sale", class: "form-label fw-semibold" %>
        <%= select_tag :on_sale,
                       options_for_select(on_sale_options, @selected_on_sale),
                       class: "form-select" %>
      </div>

      <div class="col-12 col-md-3 col-xl-2">
        <%= label_tag :category_id, "Category", class: "form-label fw-semibold" %>
        <%= select_tag :category_id,
                       options_from_collection_for_select(@categories, :id, :name, @selected_category&.id),
                       include_blank: "All Categories",
                       class: "form-select" %>
      </div>

      <div class="col-12 col-md-6 col-xl-3">
        <%= label_tag :sort, "Sort By Price", class: "form-label fw-semibold" %>
        <%= select_tag :sort,
                       options_for_select(price_sort_options, @selected_sort),
                       class: "form-select" %>
      </div>

      <div class="col-12 col-md-6 col-xl-3">
        <div class="d-flex gap-2">
          <%= submit_tag "Search", class: "btn btn-primary flex-grow-1" %>
          <%= link_to "Reset", products_path, class: "btn btn-outline-secondary" %>
        </div>
      </div>
    <% end %>
  </div>
</section>

<% if @products.any? %>
  <section class="row row-cols-1 row-cols-lg-2 g-3 product-grid mb-4">
    <% @products.each do |product| %>
      <div class="col">
        <article class="product-card">
          <div class="product-card__image">
            <% if product.image.attached? %>
              <%= image_tag product.image, alt: product.title %>
            <% else %>
              <div class="product-card__placeholder">Product image coming soon</div>
            <% end %>
          </div>

          <div class="card-body d-flex flex-column p-3">
            <div class="d-flex flex-wrap gap-2 mb-2">
              <span class="badge text-bg-light border"><%= product.category.name %></span>
              <% if product.on_sale? %>
                <span class="badge text-bg-warning">On Sale</span>
              <% end %>
            </div>

            <h3 class="product-card__title h5 fw-bold mb-1"><%= product.title %></h3>
            <p class="product-card__meta text-muted mb-2">Stock: <%= product.stock_quantity %></p>
            <p class="product-card__description text-muted mb-3 flex-grow-1">
              <%= truncate(product.description, length: 90) %>
            </p>

            <div class="d-flex justify-content-between align-items-end mt-auto gap-3">
              <div class="product-card__pricing">
                <% if show_discount_price?(product) %>
                  <div class="product-discount-text"><%= number_to_percentage(product.discount_percentage, precision: 0) %> off!</div>
                  <div class="d-flex flex-wrap align-items-center gap-2">
                    <span class="product-sale-price"><%= number_to_currency(discounted_price(product)) %></span>
                    <span class="product-original-price"><%= number_to_currency(product.price) %></span>
                  </div>
                <% else %>
                  <span class="fs-5 fw-bold text-primary"><%= number_to_currency(product.price) %></span>
                <% end %>
              </div>

              <%= link_to "View Details", product_path(product), class: "btn btn-outline-secondary product-card__cta" %>
            </div>
          </div>
        </article>
      </div>
    <% end %>
  </section>

  <div class="mt-4">
    <%= paginate @products %>
  </div>
<% else %>
  <section class="catalog-empty p-5 text-center">
    <h2 class="h4 fw-bold mb-2">No products matched your search.</h2>
    <p class="text-muted mb-4">Try adjusting the product name, price range, sale status, or category filters.</p>
    <%= link_to "Back to all products", products_path, class: "btn btn-primary" %>
  </section>
<% end %>
