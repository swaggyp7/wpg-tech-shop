<section class="product-show">
  <div class="product-show__panel p-3 p-lg-4">
    <div class="row g-4 align-items-start">
      <div class="col-lg-5">
        <div class="product-show__image">
          <% if @product.image.attached? %>
            <%= image_tag @product.image, alt: @product.title %>
          <% else %>
            <div class="product-show__placeholder">Product image coming soon</div>
          <% end %>
        </div>
      </div>

      <div class="col-lg-7">
        <div class="d-flex flex-wrap gap-2 mb-3">
          <span class="badge text-bg-light border"><%= @product.category.name %></span>
          <% if @product.on_sale? %>
            <span class="badge text-bg-warning">On Sale</span>
          <% end %>
        </div>

        <h1 class="product-show__title h2 mb-2"><%= @product.title %></h1>
        <p class="product-show__meta mb-3">Stock available: <%= @product.stock_quantity %></p>

        <div class="product-show__price-block mb-4">
          <% if show_discount_price?(@product) %>
            <div class="product-discount-text"><%= number_to_percentage(@product.discount_percentage, precision: 0) %> off!</div>
            <div class="d-flex flex-wrap align-items-center gap-2">
              <span class="product-sale-price"><%= number_to_currency(discounted_price(@product)) %></span>
              <span class="product-original-price"><%= number_to_currency(@product.price) %></span>
            </div>
          <% else %>
            <span class="product-show__regular-price"><%= number_to_currency(@product.price) %></span>
          <% end %>
        </div>

        <div class="product-show__purchase mb-4">
          <div class="product-show__purchase-label">Quantity</div>
          <div class="product-quantity-picker mb-3">
            <button type="button" class="product-quantity-picker__button" aria-label="Decrease quantity">-</button>
            <%= number_field_tag :quantity,
                                 @quantity,
                                 min: 1,
                                 step: 1,
                                 class: "product-quantity-picker__input",
                                 aria: { label: "Quantity" } %>
            <button type="button" class="product-quantity-picker__button" aria-label="Increase quantity">+</button>
          </div>

          <button type="button" class="btn btn-primary product-show__cart-button">Add to Cart</button>
          <p class="product-show__cart-note mt-2 mb-0">Cart functionality coming soon. This button is currently for layout only.</p>
        </div>

        <div class="product-show__description">
          <h2 class="h5 mb-2">Product Details</h2>
          <p class="mb-0"><%= @product.description %></p>
        </div>
      </div>
    </div>
  </div>
</section>
